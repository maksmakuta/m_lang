fn<T> abs(val : T) : T{
    return val > as<T>(0) ?: -val
}

fn<T> min(a : T, b : T) : T{
    return a < b ? a : b
}

fn<T> min(a : T, b : T, c : T) : T{
    return min(min(a,b),c)
}

fn<T> max(a : T, b : T, c : T) : T{
    return max(max(a,b),c)
}

fn<T> avg(a : T, b : T) : T{
    return (a + b) / as<T>(2)
}

fn<T> avg(a : T, b : T, c : T) : T{
    return (a + b + c) / as<T>(3)
}