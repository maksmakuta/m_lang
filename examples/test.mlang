
fn main(){
    for(i : i32 in 0 .. 5){
        println(i)
    }

    let data = vec<i32>()

    for(i : i32 in 56 .. 95){ // for(int i = 56; i < 95; ++i)
        data.push(i)
    }

    for(i : i32 in 0 ..= 9){ // for(int i = 0; i <= 9; ++i)
        data.push(i)
    }

    for(i : i32 in data){
        println(i)
    }

}

